# kino environment configuration
# Copy to .env and fill in your values.
# docker-compose reads .env automatically.

# Server
KINO_PORT=8080
KINO_DATA_PATH=./data
RUST_LOG=info

# TMDB API Read Access Token (get from https://www.themoviedb.org/settings/api)
# Set this to skip the TMDB setup step on first launch.
KINO_TMDB_API_KEY=

# Media library and download paths
KINO_MEDIA_PATH=/workspace/data/library
KINO_DOWNLOAD_PATH=/workspace/data/downloads

# Prowlarr integration (optional — auto-adds as indexer on first run)
# Get the API key from Prowlarr UI → Settings → General → API Key
# The URL is a Torznab endpoint, e.g. http://localhost:9696/1/api
KINO_PROWLARR_URL=
KINO_PROWLARR_API_KEY=
