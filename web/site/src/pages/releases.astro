---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import { PLATFORM_ICON_PATHS } from "@/lib/platform-icons";
import {
  type AssetGrouped,
  fetchReleases,
  fetchShaMap,
  formatBytes,
  formatDate,
  groupByOs,
  type OsGroup,
  type Release,
} from "@/lib/releases";

const releases = await fetchReleases();
const latest = releases.find((r) => !r.prerelease) ?? null;
const earlier = releases.filter((r) => r !== latest);

// Per-OS rendering metadata for the latest release's asset grid.
const OS_META: Record<OsGroup, { label: string; iconKey: keyof typeof PLATFORM_ICON_PATHS }> = {
  linux: { label: "Linux", iconKey: "linux" },
  macos: { label: "macOS", iconKey: "apple" },
  windows: { label: "Windows", iconKey: "microsoft" },
  "raspberry-pi": { label: "Raspberry Pi", iconKey: "raspberrypi" },
  source: { label: "Source", iconKey: "github" },
  other: { label: "Other", iconKey: "github" },
};

const SHORT_SHA = (s: string | undefined) => (s ? s.slice(0, 12) : null);

function renderMarkdown(body: string): string {
  // Minimal markdown → HTML. Release notes from release-please /
  // cargo-dist are predictable: ## headings, * bullets, ** bold,
  // backtick code, [text](url) links.
  let html = body
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(
      /`([^`]+)`/g,
      '<code class="rounded bg-white/5 px-1.5 py-0.5 text-xs font-mono">$1</code>'
    )
    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
    .replace(
      /\[([^\]]+)\]\(([^)]+)\)/g,
      '<a href="$2" class="underline underline-offset-2 hover:text-[var(--color-fg)]" rel="noopener noreferrer">$1</a>'
    );
  const lines = html.split("\n");
  const out: string[] = [];
  let inList = false;
  for (const line of lines) {
    if (/^### /.test(line)) {
      if (inList) {
        out.push("</ul>");
        inList = false;
      }
      out.push(
        `<h4 class="mt-5 mb-2 text-sm font-semibold uppercase tracking-wide text-[var(--color-fg)]">${line.replace(/^### /, "")}</h4>`
      );
    } else if (/^## /.test(line)) {
      if (inList) {
        out.push("</ul>");
        inList = false;
      }
      out.push(
        `<h3 class="mt-6 mb-2 text-base font-semibold text-[var(--color-fg)]">${line.replace(/^## /, "")}</h3>`
      );
    } else if (/^[*-] /.test(line)) {
      if (!inList) {
        out.push('<ul class="my-2 ml-5 list-disc space-y-1 text-sm">');
        inList = true;
      }
      out.push(`<li>${line.replace(/^[*-] /, "")}</li>`);
    } else if (line.trim() === "") {
      if (inList) {
        out.push("</ul>");
        inList = false;
      }
    } else {
      if (inList) {
        out.push("</ul>");
        inList = false;
      }
      out.push(`<p class="my-2 text-sm">${line}</p>`);
    }
  }
  if (inList) out.push("</ul>");
  return out.join("\n");
}

interface Rendered {
  groups: Map<OsGroup, AssetGrouped[]>;
  bodyHtml: string;
  totalDownloads: number;
}
function renderRelease(r: Release): Rendered {
  return {
    groups: groupByOs(r.assets),
    bodyHtml: renderMarkdown(r.body),
    totalDownloads: r.assets.reduce((sum, a) => sum + a.download_count, 0),
  };
}

const latestRendered = latest ? renderRelease(latest) : null;
const latestShaMap = latest ? await fetchShaMap(latest) : new Map<string, string>();
---

<MarketingLayout
  title="Releases · kino"
  description="Version history and downloads for kino — every release with changelogs and per-platform artefacts."
>
  <header class="mb-10">
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      <h1 class="text-4xl font-semibold tracking-tight">Releases</h1>
      <p class="text-xs text-[var(--color-fg-muted)]">
        <a
          href="https://github.com/kinostack-app/kino/releases.atom"
          class="underline hover:text-[var(--color-fg)]"
          rel="noopener noreferrer"
        >RSS feed</a>
        <span class="mx-2 opacity-50">·</span>
        <a
          href="https://github.com/kinostack-app/kino/releases"
          class="underline hover:text-[var(--color-fg)]"
          rel="noopener noreferrer"
        >GitHub ↗</a>
      </p>
    </div>
    <p class="mt-3 text-sm text-[var(--color-fg-muted)]">
      Every kino release with its downloads + release notes, newest first. Want
      install help instead? See <a href="/download" class="underline hover:text-[var(--color-fg)]">Download</a>.
    </p>
  </header>

  {!latest && (
    <section class="rounded-xl border border-[var(--color-line)] bg-[var(--color-elevated)] p-10 text-center">
      <h2 class="text-2xl font-semibold">First release coming soon</h2>
      <p class="mt-3 text-sm text-[var(--color-fg-muted)]">
        kino hasn't shipped a stable release yet. Once the first
        version tags, this page lights up automatically with downloads
        and changelog.
      </p>
      <p class="mt-6 text-xs text-[var(--color-fg-muted)]">
        Watch the
        <a
          href="https://github.com/kinostack-app/kino"
          class="underline hover:text-[var(--color-fg)]"
          rel="noopener noreferrer"
        >GitHub repo</a>
        to be notified.
      </p>
    </section>
  )}

  {latest && latestRendered && (
    <section class="rounded-xl border border-[var(--color-line)] bg-[var(--color-elevated)] p-7 ring-1 ring-[var(--color-accent)]/20">
      <header class="flex flex-wrap items-baseline justify-between gap-3">
        <div class="flex items-baseline gap-3">
          <h2 class="font-mono text-2xl font-semibold tracking-tight text-[var(--color-fg)]">
            {latest.tag}
          </h2>
          <span class="rounded-full bg-[var(--color-accent)]/15 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide text-[var(--color-accent)]">
            Latest
          </span>
        </div>
        <p class="text-xs text-[var(--color-fg-muted)]">
          Released {formatDate(latest.published_at)}
          <span class="mx-2 opacity-50">·</span>
          <a
            href={latest.html_url}
            class="underline hover:text-[var(--color-fg)]"
            rel="noopener noreferrer"
          >View on GitHub ↗</a>
        </p>
      </header>

      {latestRendered.groups.size > 0 && (
        <div class="mt-6">
          <p class="text-[10px] font-medium uppercase tracking-wide text-[var(--color-fg-muted)]">
            Downloads
          </p>
          <div class="mt-2 overflow-x-auto rounded-lg border border-[var(--color-line)] bg-black/20">
            <table class="w-full text-left text-xs">
              <thead class="bg-white/[0.03] text-[10px] font-semibold uppercase tracking-wide text-[var(--color-fg-muted)]">
                <tr>
                  <th class="px-3 py-2 font-semibold">Platform</th>
                  <th class="px-3 py-2 font-semibold">File</th>
                  <th class="px-3 py-2 text-right font-semibold">Size</th>
                  <th class="px-3 py-2 font-semibold">SHA-256</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-[var(--color-line)]">
                {Array.from(latestRendered.groups.entries()).flatMap(([os, assets]) => {
                  const meta = OS_META[os];
                  return assets.map((a, i) => {
                    const fullSha = latestShaMap.get(a.name);
                    const sha = SHORT_SHA(fullSha);
                    return (
                      <tr class="hover:bg-white/[0.02]">
                        <td class="px-3 py-2 align-top">
                          {i === 0 ? (
                            <div class="flex items-center gap-2">
                              <svg
                                class="size-4 shrink-0 fill-[var(--color-fg-muted)]"
                                viewBox="0 0 24 24"
                                aria-hidden="true"
                                set:html={`<path d="${PLATFORM_ICON_PATHS[meta.iconKey]}"/>`}
                              />
                              <span class="font-medium text-[var(--color-fg)]">{meta.label}</span>
                            </div>
                          ) : (
                            <span class="text-[var(--color-fg-muted)]/50">↳</span>
                          )}
                        </td>
                        <td class="px-3 py-2 align-top">
                          <a
                            href={a.download_url}
                            class="text-[var(--color-fg)] underline-offset-2 hover:underline hover:text-[var(--color-accent)]"
                            rel="noopener"
                          >
                            {a.label}
                          </a>
                        </td>
                        <td class="px-3 py-2 text-right align-top font-mono text-[10px] text-[var(--color-fg-muted)] whitespace-nowrap">
                          {formatBytes(a.size)}
                        </td>
                        <td class="px-3 py-2 align-top">
                          {sha ? (
                            <button
                              type="button"
                              class="copy-btn font-mono text-[10px] text-[var(--color-fg-muted)] underline-offset-2 hover:text-[var(--color-fg)] hover:underline"
                              data-copy={fullSha}
                              title={`Copy full SHA-256: ${fullSha}`}
                              aria-label={`Copy SHA-256 for ${a.name}`}
                            >
                              {sha}…
                            </button>
                          ) : (
                            <span class="font-mono text-[10px] text-[var(--color-fg-muted)]/50">—</span>
                          )}
                        </td>
                      </tr>
                    );
                  });
                })}
              </tbody>
            </table>
          </div>
          <p class="mt-2 text-[10px] text-[var(--color-fg-muted)]">
            Click a SHA-256 to copy the full hash. Verify with <code class="rounded bg-white/5 px-1 py-0.5 font-mono">sha256sum -c sha256.sum</code> against the
            <a
              href={`https://github.com/kinostack-app/kino/releases/download/${latest.tag}/sha256.sum`}
              class="underline hover:text-[var(--color-fg)]"
              rel="noopener noreferrer"
            >combined sums file</a>.
          </p>
        </div>
      )}

      {latest.body.trim().length > 0 && (
        <div class="mt-7">
          <p class="text-[10px] font-medium uppercase tracking-wide text-[var(--color-fg-muted)]">
            What's in this release
          </p>
          <div
            class="mt-2 text-[var(--color-fg-muted)] [&_a]:text-[var(--color-fg)] [&_strong]:text-[var(--color-fg)] [&_code]:text-[var(--color-fg)]"
            set:html={latestRendered.bodyHtml}
          />
        </div>
      )}
    </section>
  )}

  {earlier.length > 0 && (
    <section class="mt-12">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-[var(--color-fg-muted)]">
        Earlier releases
      </h2>
      <ul class="divide-y divide-[var(--color-line)] overflow-hidden rounded-xl border border-[var(--color-line)]">
        {earlier.map((r) => (
          <li>
            <details class="group">
              <summary class="flex cursor-pointer items-baseline justify-between gap-3 px-5 py-4 hover:bg-white/[0.02]">
                <span class="flex items-baseline gap-3">
                  <span class="font-mono text-sm font-semibold text-[var(--color-fg)]">
                    {r.tag}
                  </span>
                  {r.prerelease && (
                    <span class="rounded-full bg-amber-500/15 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide text-amber-300">
                      pre-release
                    </span>
                  )}
                  {r.assets.length > 0 ? (
                    <span class="text-xs text-[var(--color-fg-muted)]">
                      {r.assets.length} {r.assets.length === 1 ? "asset" : "assets"}
                    </span>
                  ) : (
                    <span class="text-xs text-[var(--color-fg-muted)] italic">
                      no artefacts
                    </span>
                  )}
                </span>
                <span class="flex items-baseline gap-3">
                  <span class="text-xs text-[var(--color-fg-muted)]">
                    {formatDate(r.published_at)}
                  </span>
                  <span class="text-xs text-[var(--color-fg-muted)] transition-transform group-open:rotate-180">▾</span>
                </span>
              </summary>

              <div class="px-5 pb-5">
                {r.assets.length > 0 && (
                  <div class="mb-4 overflow-x-auto rounded-md border border-[var(--color-line)] bg-black/20">
                    <table class="w-full text-left text-xs">
                      <thead class="bg-white/[0.03] text-[10px] font-semibold uppercase tracking-wide text-[var(--color-fg-muted)]">
                        <tr>
                          <th class="px-3 py-2 font-semibold">Platform</th>
                          <th class="px-3 py-2 font-semibold">File</th>
                          <th class="px-3 py-2 text-right font-semibold">Size</th>
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-[var(--color-line)]">
                        {Array.from(groupByOs(r.assets).entries()).flatMap(([os, assets]) => {
                          const meta = OS_META[os];
                          return assets.map((a, i) => (
                            <tr class="hover:bg-white/[0.02]">
                              <td class="px-3 py-1.5 align-top">
                                {i === 0 ? (
                                  <div class="flex items-center gap-2">
                                    <svg
                                      class="size-3.5 shrink-0 fill-[var(--color-fg-muted)]"
                                      viewBox="0 0 24 24"
                                      aria-hidden="true"
                                      set:html={`<path d="${PLATFORM_ICON_PATHS[meta.iconKey]}"/>`}
                                    />
                                    <span class="text-[var(--color-fg)]/90">{meta.label}</span>
                                  </div>
                                ) : (
                                  <span class="text-[var(--color-fg-muted)]/50">↳</span>
                                )}
                              </td>
                              <td class="px-3 py-1.5 align-top">
                                <a
                                  href={a.download_url}
                                  class="text-[var(--color-fg)]/85 underline-offset-2 hover:text-[var(--color-accent)] hover:underline"
                                  rel="noopener"
                                >
                                  {a.label}
                                </a>
                              </td>
                              <td class="px-3 py-1.5 text-right align-top font-mono text-[10px] text-[var(--color-fg-muted)] whitespace-nowrap">
                                {formatBytes(a.size)}
                              </td>
                            </tr>
                          ));
                        })}
                      </tbody>
                    </table>
                  </div>
                )}

                {r.body.trim().length > 0 && (
                  <div
                    class="text-[var(--color-fg-muted)] [&_a]:text-[var(--color-fg)] [&_strong]:text-[var(--color-fg)] [&_code]:text-[var(--color-fg)]"
                    set:html={renderMarkdown(r.body)}
                  />
                )}

                <p class="mt-4 text-xs">
                  <a
                    href={r.html_url}
                    class="text-[var(--color-fg-muted)] underline hover:text-[var(--color-fg)]"
                    rel="noopener noreferrer"
                  >View on GitHub ↗</a>
                </p>
              </div>
            </details>
          </li>
        ))}
      </ul>
    </section>
  )}
</MarketingLayout>

<script is:inline>
  // Click-to-copy for SHA-256 cells in the downloads table.
  document.addEventListener("click", (e) => {
    const target = e.target instanceof HTMLElement ? e.target.closest(".copy-btn") : null;
    if (!target || !(target instanceof HTMLButtonElement)) return;
    const text = target.dataset.copy;
    if (!text) return;
    navigator.clipboard
      .writeText(text)
      .then(() => {
        const original = target.textContent;
        target.textContent = "Copied";
        target.classList.add("text-[var(--color-accent)]");
        setTimeout(() => {
          target.textContent = original;
          target.classList.remove("text-[var(--color-accent)]");
        }, 1500);
      })
      .catch(() => {
        target.textContent = "Failed";
        setTimeout(() => target.click(), 1200);
      });
  });
</script>
