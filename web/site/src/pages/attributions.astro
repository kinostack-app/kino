---
import MarketingLayout from "@/layouts/MarketingLayout.astro";

const services = [
  {
    name: "TMDB",
    href: "https://www.themoviedb.org/",
    line: "Movie + TV metadata, posters, backdrops. kino's library wouldn't exist without it.",
    required: "This product uses the TMDB API but is not endorsed or certified by TMDB.",
  },
  {
    name: "Trakt",
    href: "https://trakt.tv/",
    line: "Optional integration: watch history sync, ratings sync, list following, scrobbling.",
    required: "Not affiliated with or endorsed by Trakt.tv.",
  },
  {
    name: "OpenSubtitles",
    href: "https://www.opensubtitles.org/",
    line: "Optional integration: subtitle download for media that doesn't ship its own.",
    required: "Not affiliated with or endorsed by OpenSubtitles.",
  },
  {
    name: "MDBList",
    href: "https://mdblist.com/",
    line: "Optional integration: follow curated movie + TV lists.",
    required: null,
  },
];

const stack = [
  {
    name: "FFmpeg",
    href: "https://www.ffmpeg.org/",
    license: "GPL-3.0",
    line: "Transcoding, probing, every audio/video operation. kino does not bundle FFmpeg in its release archives — Settings → Playback offers an in-app download of upstream jellyfin-ffmpeg portable builds. Source-offer obligations under GPL §6 rest with Jellyfin as the redistributor of the binary kino fetches; see docs/third-party/ffmpeg-source-offer.md.",
  },
  {
    name: "boringtun",
    href: "https://github.com/cloudflare/boringtun",
    license: "BSD-3-Clause",
    line: "Userspace WireGuard implementation. Built-in privacy networking is a thin wrapper around boringtun + the tun crate.",
  },
  {
    name: "librqbit",
    href: "https://github.com/ikatson/rqbit",
    license: "Apache-2.0",
    line: "BitTorrent client embedded directly in the kino binary. No external download client required.",
  },
  {
    name: "Cardigann YAML format",
    href: "https://github.com/cardigann/cardigann",
    license: "GPL-2.0",
    line: "Indexer definition format originated by the Cardigann project. kino's indexer engine consumes definitions in this format when the user opts in.",
  },
  {
    name: "Astro + Starlight",
    href: "https://astro.build/",
    license: "MIT",
    line: "Powers this website (kinostack.app) and the docs site (docs.kinostack.app).",
  },
  {
    name: "shadcn/ui + Radix",
    href: "https://ui.shadcn.com/",
    license: "MIT",
    line: "UI primitives (dialogs, dropdowns, tooltips) inside the in-app SPA.",
  },
];
---

<MarketingLayout
  title="Attributions · kino"
  description="Third-party services and dependencies that kino integrates with — TMDB, Trakt, OpenSubtitles, MDBList, FFmpeg, librqbit, and the broader OSS ecosystem."
>
  <header class="mb-12">
    <h1 class="text-4xl font-semibold tracking-tight">Attributions</h1>
    <p class="mt-3 max-w-2xl text-[var(--color-fg-muted)]">
      kino stands on the shoulders of an enormous amount of open-source
      software and a handful of third-party services. This page
      acknowledges the load-bearing pieces.
    </p>
  </header>

  <section>
    <h2 class="mb-4 text-2xl font-semibold tracking-tight">Third-party services</h2>
    <ul class="space-y-4">
      {services.map((s) => (
        <li
          class="rounded-lg border border-[var(--color-line)] bg-[var(--color-elevated)] p-5"
        >
          <h3 class="text-lg font-semibold">
            <a
              href={s.href}
              class="underline-offset-2 hover:underline"
              rel="noopener noreferrer"
            >{s.name} ↗</a>
          </h3>
          <p class="mt-2 text-sm text-[var(--color-fg-muted)]">{s.line}</p>
          {s.required && (
            <p class="mt-2 text-xs italic text-[var(--color-fg-muted)]">{s.required}</p>
          )}
        </li>
      ))}
    </ul>
  </section>

  <section class="mt-16">
    <h2 class="mb-4 text-2xl font-semibold tracking-tight">Notable open-source dependencies</h2>
    <p class="mb-4 text-sm text-[var(--color-fg-muted)]">
      Selected highlights — kino's full SBOM (every Rust crate + npm
      package, generated by cargo-about) lives at
      <code class="rounded bg-white/5 px-1.5 py-0.5 text-xs">THIRD_PARTY_LICENSES.md</code>
      in each release archive.
    </p>
    <ul class="divide-y divide-[var(--color-line)] rounded-lg border border-[var(--color-line)]">
      {stack.map((d) => (
        <li class="px-5 py-4">
          <div class="flex items-baseline justify-between gap-3">
            <h3 class="font-semibold">
              <a
                href={d.href}
                class="underline-offset-2 hover:underline"
                rel="noopener noreferrer"
              >{d.name} ↗</a>
            </h3>
            <span class="text-xs text-[var(--color-fg-muted)]">{d.license}</span>
          </div>
          <p class="mt-1 text-sm text-[var(--color-fg-muted)]">{d.line}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="mt-16 rounded-lg border border-[var(--color-line)] bg-[var(--color-elevated)] p-6">
    <h2 class="text-lg font-semibold">Licensing posture</h2>
    <p class="mt-3 text-sm text-[var(--color-fg-muted)]">
      kino itself is licensed under
      <a
        href="https://www.gnu.org/licenses/gpl-3.0"
        class="underline hover:text-[var(--color-fg)]"
        rel="noopener noreferrer"
      >GPL-3.0-or-later</a>.
      Every dependency we ship is GPL-compatible (MIT, Apache-2.0,
      BSD, ISC, MPL-2.0, LGPL-3.0, or other GPL-3.0). Drift is
      caught automatically by
      <code class="rounded bg-white/5 px-1.5 py-0.5 text-xs">cargo-deny</code>
      on every build.
    </p>
  </section>
</MarketingLayout>
