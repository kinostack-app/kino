# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Web frontends and TS / JS conventionally indent at 2.
[*.{ts,tsx,js,jsx,json,jsonc,html,css,scss,vue,svelte,astro,mdx,yml,yaml}]
indent_size = 2

# Markdown — preserve trailing whitespace (it's how line breaks work)
# and don't enforce final newline (some authoring tools strip it).
[*.md]
trim_trailing_whitespace = false

# Makefiles must use tabs.
[{Makefile,*.mk}]
indent_style = tab

# Windows line-endings stay only where Windows tooling requires them.
[*.{bat,cmd,ps1}]
end_of_line = crlf
