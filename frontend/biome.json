{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "files": {
    "includes": ["src/**", "!src/api/generated", "!coverage", "!dist"],
    "maxSize": 2097152
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off"
      },
      "a11y": {
        "useSemanticElements": "warn",
        "noNoninteractiveTabindex": "warn",
        "noStaticElementInteractions": "warn",
        "useKeyWithClickEvents": "warn",
        "noLabelWithoutControl": "warn"
      }
    }
  },
  "javascript": {
    "parser": {
      "jsxEverywhere": true
    },
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5",
      "semicolons": "always",
      "bracketSpacing": true,
      "bracketSameLine": false,
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["src/**/*.test.{ts,tsx}", "src/**/__tests__/**"],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off" },
          "complexity": { "noExcessiveCognitiveComplexity": "off" }
        }
      }
    },
    {
      "includes": ["src/components/ui/**"],
      "linter": {
        "rules": {
          "correctness": { "noNestedComponentDefinitions": "off" }
        }
      }
    },
    {
      "includes": ["src/**/*.css"],
      "linter": {
        "rules": {
          "suspicious": { "noUnknownAtRules": "off" },
          "complexity": { "noImportantStyles": "off" }
        }
      }
    },
    {
      "includes": ["src/api/generated/**"],
      "linter": { "enabled": false },
      "formatter": { "enabled": false }
    }
  ]
}
