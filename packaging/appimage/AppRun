#!/bin/sh
# AppImage entry point. AppImages mount the AppDir read-only at
# /tmp/.mount_<random> on launch, so $APPDIR points at the layout
# we built in the workflow. We just exec the binary with whatever
# arguments the user passed; the binary itself handles
# `serve` / `tray` / `install-service` / etc. via clap.
HERE="$(dirname "$(readlink -f "$0")")"
exec "$HERE/usr/bin/kino" "$@"
