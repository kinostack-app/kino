{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "rust",
  "include-component-in-tag": false,
  "tag-separator": "v",
  "draft": false,
  "prerelease": false,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "changelog-path": "CHANGELOG.md",
  "changelog-sections": [
    { "type": "feat",     "section": "Added",   "hidden": false },
    { "type": "feature",  "section": "Added",   "hidden": false },
    { "type": "fix",      "section": "Fixed",   "hidden": false },
    { "type": "perf",     "section": "Changed", "hidden": false },
    { "type": "revert",   "section": "Changed", "hidden": false },
    { "type": "refactor", "section": "Changed", "hidden": false },
    { "type": "docs",     "section": "Docs",    "hidden": false },
    { "type": "build",    "section": "Build",   "hidden": true  },
    { "type": "ci",       "section": "CI",      "hidden": true  },
    { "type": "chore",    "section": "Chore",   "hidden": true  },
    { "type": "style",    "section": "Style",   "hidden": true  },
    { "type": "test",     "section": "Tests",   "hidden": true  }
  ],
  "packages": {
    "backend/crates/kino": {
      "package-name": "kino",
      "comment": "Single 'kino' product = backend Rust binary + frontend React SPA bundled together. The crate's Cargo.toml is the canonical version (release-type=rust drives the bump). `extra-files` keeps frontend/package.json in lockstep so the SPA's package.json mirrors the binary's version. `paths` widens commit-filtering past the crate dir to packaging/CI/frontend, so e.g. `fix(packaging)` commits land in the kino CHANGELOG. The marketing site (web/site/) and docs site (web/docs/) are deliberately NOT in this scope — they're continuously deployed by Cloudflare Workers Builds on push, no version, no release.",
      "paths": [
        "backend",
        "frontend",
        "packaging",
        ".github/workflows/release.yml",
        ".github/workflows/release-please.yml",
        ".github/workflows/channels.yml",
        ".github/workflows/cross-os.yml",
        ".github/workflows/ci.yml"
      ],
      "extra-files": [
        {
          "type": "json",
          "path": "frontend/package.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
