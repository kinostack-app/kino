FROM rust:1.94-bookworm

# System tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Build essentials (cmake is required by boring-sys2 for BoringSSL)
    clang mold pkg-config libssl-dev cmake \
    # FFmpeg for media probing + transcoding + trickplay sprites
    ffmpeg \
    # Archive extraction for import pipeline (6.1)
    unrar-free \
    # iproute2 for VPN default-route setup (userspace WireGuard)
    iproute2 \
    # Docker CLI (for managing sibling containers from dev shell).
    # Compose plugin gets installed below as a static binary —
    # apt's docker-compose-plugin pulls in too many dependencies.
    docker.io \
    # Headless Chrome dependencies (for Cloudflare challenge solving)
    libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libxcomposite1 \
    libxdamage1 libxrandr2 libgbm1 libpango-1.0-0 libcairo2 libasound2 \
    libxshmfence1 fonts-liberation \
    # Subsystem 22 (desktop tray) build deps. The tray-icon crate's
    # Linux backend links GTK + libayatana-appindicator (SNI over D-Bus)
    # + libxdo (X11 input simulation) at compile time. We can't
    # actually *render* a tray icon inside this container — the
    # `kino-backend` service builds with `--no-default-features` and
    # never touches the GUI path — but having the headers here lets
    # `cargo check --features tray` work in the dev shell so tray code
    # is type-checked before it hits CI / a developer's host.
    libgtk-3-dev libayatana-appindicator3-dev libxdo-dev \
    # Tools
    curl git jq vim nano tree fzf \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22 LTS
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Docker compose plugin — needed to manage the sibling
# backend / frontend / web containers from inside the dev shell
# (the post-create script can't reach the host's compose). Static
# binary install survives image rebuilds. Pinned to v2.31.0.
RUN mkdir -p /usr/libexec/docker/cli-plugins && \
    curl -fsSL "https://github.com/docker/compose/releases/download/v2.31.0/docker-compose-linux-x86_64" \
        -o /usr/libexec/docker/cli-plugins/docker-compose && \
    chmod +x /usr/libexec/docker/cli-plugins/docker-compose

# Rust tools
RUN cargo install --locked watchexec-cli cargo-nextest just

# Workflow security analyser (matches the `zizmor.yml` CI step) +
# dep-policy linter (matches `just deny`). Prebuilt binary downloads;
# faster + smaller than `cargo install`.
RUN ZIZMOR_VERSION=1.24.1 && \
    curl -fsSL "https://github.com/zizmorcore/zizmor/releases/download/v${ZIZMOR_VERSION}/zizmor-x86_64-unknown-linux-gnu.tar.gz" \
        | tar xz -C /usr/local/bin/ zizmor && \
    chmod +x /usr/local/bin/zizmor && \
    zizmor --version
RUN cargo install --locked cargo-deny

# Claude Code
RUN curl -fsSL https://claude.ai/install.sh | bash -s latest || \
    echo "Claude Code installation failed - install manually"
ENV PATH="/root/.local/bin:${PATH}"

# GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
    apt-get update && \
    apt-get install -y --no-install-recommends gh && \
    rm -rf /var/lib/apt/lists/*

# Working directory
WORKDIR /workspace

# Keep container running
CMD ["sleep", "infinity"]
